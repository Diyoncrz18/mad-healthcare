GEMINI_API_KEY=your_google_cloud_bearer_token_or_access_token_here
PORT=3000

# NOTE:
# - For Google Generative Models you typically use a service account access token (Bearer) or
#   a properly scoped OAuth token. If you have an API key only, you may need to adjust the
#   server to pass it as `?key=API_KEY` instead of an Authorization header.
