# ───────────── Supabase ─────────────
# URL project Supabase (sama dengan yang dipakai client).
SUPABASE_URL=https://abobncsoyqdbqemkssrf.supabase.co

# Service Role Key — WAJIB rahasia. Hanya hidup di server.
# Ambil dari Supabase Dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=replace_me_with_service_role

# Anon key dipakai untuk verifikasi JWT user yang connect.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFib2JuY3NveXFkYnFlbWtzc3JmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU1NDgyMjgsImV4cCI6MjA5MTEyNDIyOH0.Si1FJ_Teo7Xs5b4Cd7Z_WvjZ-026alncnb8fsD_1k1c

# ───────────── Server ─────────────
PORT=4000
# CORS — koma-separated daftar origin yang diizinkan; pakai * untuk dev.
CORS_ORIGIN=*

# ───────────── Gemini AI (HealthcareBot) ─────────────
# API Key Gemini — WAJIB rahasia. Hanya hidup di server.
# Ambil dari https://aistudio.google.com/app/apikey
GEMINI_API_KEY=replace_me_with_gemini_api_key

# Model & versi (opsional). Default: gemini-2.5-flash via API v1beta.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_VERSION=v1beta

# Timeout (ms) panggilan ke Gemini API. Cegah request lambat menahan
# koneksi server. Default 15 detik.
GEMINI_FETCH_TIMEOUT_MS=15000
